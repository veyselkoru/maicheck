# mAicheck v3.1 — .env.example
# PostgreSQL
DATABASE_URL="postgresql://maicheck:maicheck123@postgres:5432/maicheck_db?schema=public"

# JWT
JWT_SECRET="maicheck-v31-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# CORS
FRONTEND_URL="http://localhost:5173"

# File upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=100

# Logo storage
LOGO_DIR="./uploads/logos"
